generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  logo           String?
  iconBgColor    String   @default("#ffffff") @map("icon_bg_color")
  primaryColor   String   @default("#1e40af") @map("primary_color")
  secondaryColor String   @default("#3b82f6") @map("secondary_color")
  vertical       String   @default("mecanica")
  businessType   String   @default("geral") @map("business_type")
  active         Boolean  @default(true)
  plan           String   @default("basic")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Dados institucionais
  razaoSocial        String?  @map("razao_social")
  cnpj               String?
  inscricaoEstadual  String?  @map("inscricao_estadual")
  inscricaoMunicipal String?  @map("inscricao_municipal")
  porte              String?
  site               String?
  telefone           String?

  // Endereço
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?

  // Responsável principal
  responsavelNome     String? @map("responsavel_nome")
  responsavelEmail    String? @map("responsavel_email")
  responsavelTelefone String? @map("responsavel_telefone")
  responsavelCargo    String? @map("responsavel_cargo")

  // Comercial / Contrato
  planStatus      String    @default("ativo") @map("plan_status")
  planValue       Float?    @map("plan_value")
  planBillingType String?   @map("plan_billing_type")
  planStartDate   DateTime? @map("plan_start_date")
  planEndDate     DateTime? @map("plan_end_date")
  planNotes       String?   @map("plan_notes")
  maxUsers        Int       @default(10) @map("max_users")

  // Onboarding
  onboardingStatus  String  @default("pendente") @map("onboarding_status")

  // Soft delete
  deletedAt DateTime? @map("deleted_at")

  // Contrato
  contractStatus      String    @default("nao_gerado") @map("contract_status")
  contractGeneratedAt DateTime? @map("contract_generated_at")
  contractSentAt      DateTime? @map("contract_sent_at")
  contractSentTo      String?   @map("contract_sent_to")
  contractSignedAt    DateTime? @map("contract_signed_at")
  contractSignedBy    String?   @map("contract_signed_by")
  contractFileUrl     String?   @map("contract_file_url")
  contractNotes       String?   @map("contract_notes")

  users         User[]
  clients       Client[]
  vehicles      Vehicle[]
  items         Item[]
  services      Service[]
  serviceOrders ServiceOrder[]
  warranties    Warranty[]
  financials    Financial[]
  modules    TenantModule[]
  auditLogs  TenantAuditLog[]

  // Hotel
  guests       Guest[]
  roomTypes    RoomType[]
  rooms        Room[]
  reservations Reservation[]
  housekeepingTasks HousekeepingTask[]

  @@map("tenants")
}

model TenantAuditLog {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  action       String
  category     String   @default("geral")
  description  String
  performedBy  String   @map("performed_by")
  performedAt  DateTime @default(now()) @map("performed_at")
  meta         String?  // JSON string for extra context

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_audit_logs")
}

model TenantModule {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  module   String
  active   Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, module])
  @@map("tenant_modules")
}

model User {
  id        String   @id @default(uuid())
  tenantId  String?  @map("tenant_id")
  name      String
  email     String   @unique
  password  String
  role      String   @default("mechanic")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Client {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  email     String?
  phone     String?
  document  String?
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicles      Vehicle[]
  serviceOrders ServiceOrder[]
  warranties    Warranty[]

  @@map("clients")
}

model Vehicle {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  clientId  String   @map("client_id")
  plate     String
  brand     String?
  model     String?
  year      Int?
  color     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceOrders ServiceOrder[]

  @@map("vehicles")
}

model Item {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name          String
  description   String?
  costPrice     Float    @default(0) @map("cost_price")
  sellPrice     Float    @default(0) @map("sell_price")
  stockQuantity Int      @default(0) @map("stock_quantity")
  category      String?
  unit          String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItems ServiceOrderItem[]

  @@map("items")
}

model Service {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name          String
  description   String?
  price         Float    @default(0)
  estimatedTime String?  @map("estimated_time")
  category      String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderServices ServiceOrderService[]

  @@map("services")
}

model ServiceOrder {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  clientId    String    @map("client_id")
  vehicleId   String?   @map("vehicle_id")
  status      String    @default("pending")
  description String?
  total       Float     @default(0)
  profit      Float     @default(0)
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vehicle  Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  items      ServiceOrderItem[]
  services   ServiceOrderService[]
  warranties Warranty[]
  financials Financial[]

  @@map("service_orders")
}

model ServiceOrderItem {
  id             String @id @default(uuid())
  serviceOrderId String @map("service_order_id")
  itemId         String @map("item_id")
  quantity       Int    @default(1)
  unitPrice      Float  @map("unit_price")
  total          Float

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("service_order_items")
}

model ServiceOrderService {
  id             String @id @default(uuid())
  serviceOrderId String @map("service_order_id")
  serviceId      String @map("service_id")
  quantity       Int    @default(1)
  unitPrice      Float  @map("unit_price")
  total          Float

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("service_order_services")
}

model Warranty {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  serviceOrderId String?  @map("service_order_id")
  clientId       String   @map("client_id")
  status         String   @default("active")
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("warranties")
}

model Financial {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  type           String
  category       String?
  description    String?
  value          Float
  date           DateTime
  serviceOrderId String?  @map("service_order_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)

  @@map("financials")
}

// ── Hotel vertical ────────────────────────────────────────────────────────────

model Guest {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  name         String
  email        String?
  phone        String?
  document     String?
  documentType String?  @default("cpf") @map("document_type")
  nationality  String?  @default("BR")
  address      String?
  notes        String?
  vip          Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@map("guests")
}

model RoomType {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  capacity    Int      @default(2)
  basePrice   Float    @map("base_price")
  amenities   String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rooms  Room[]

  @@map("room_types")
}

model Room {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  roomTypeId String   @map("room_type_id")
  number     String
  floor      Int      @default(1)
  status     String   @default("available")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roomType     RoomType           @relation(fields: [roomTypeId], references: [id])
  reservations Reservation[]
  housekeeping HousekeepingTask[]

  @@unique([tenantId, number])
  @@map("rooms")
}

model Reservation {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  guestId    String   @map("guest_id")
  roomId     String   @map("room_id")
  checkIn    DateTime @map("check_in")
  checkOut   DateTime @map("check_out")
  status     String   @default("confirmed")
  adults     Int      @default(1)
  children   Int      @default(0)
  totalPrice Float    @default(0) @map("total_price")
  notes      String?
  source     String?  @default("direct")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guest  Guest  @relation(fields: [guestId], references: [id])
  room   Room   @relation(fields: [roomId], references: [id])

  @@map("reservations")
}

model HousekeepingTask {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  roomId      String    @map("room_id")
  assignedTo  String?   @map("assigned_to")
  status      String    @default("pending")
  priority    String    @default("normal")
  type        String    @default("checkout")
  notes       String?
  scheduledAt DateTime? @map("scheduled_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room   Room   @relation(fields: [roomId], references: [id])

  @@map("housekeeping_tasks")
}
